{
    "name": "benjamincrozat/laravel-boilerplate",
    "description": "Opinionated way to start a new Laravel project.",
    "keywords": ["boilerplate", "framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.2",
        "algolia/algoliasearch-client-php": "^1.27",
        "benjamincrozat/laravel-blade-sugar": "^4.0",
        "fideloper/proxy": "^4.0",
        "laravel/framework": "5.7.*",
        "laravel/horizon": "^1.3",
        "laravel/scout": "^4.0",
        "laravel/socialite": "^3.0",
        "laravel/tinker": "^1.0",
        "nothingworks/blade-svg": "^0.3.0",
        "predis/predis": "^1.0"
    },
    "require-dev": {
        "beyondcode/laravel-dump-server": "~1.0",
        "codedungeon/phpunit-result-printer": "0.*",
        "doctrine/dbal": "^2.7",
        "filp/whoops": "^2.0",
        "fzaninotto/faker": "^1.0",
        "itsgoingd/clockwork": "^2.0",
        "laravel/dusk": "^3.0",
        "laravel/homestead": "^7.1",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^2.0",
        "phpunit/phpunit": "^7.0",
        "shipping-docker/vessel": "^3.0"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "itsgoingd/clockwork",
                "laravel/dusk"
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover",
            "@php artisan vendor:publish --provider='Laravel\\Horizon\\HorizonServiceProvider'"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
